<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.alis.maven</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/Users/alis_mini/.pyenv/versions/3.11.11/bin/python3</string>
        <string>/Users/alis_mini/.openclaw/workspace/scripts/maven/maven.py</string>
        <string>--once</string>
    </array>
    
    <key>StartInterval</key>
    <integer>300</integer>
    
